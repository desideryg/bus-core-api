# Root of the Lombok configuration tree. Nothing above this directory is consulted.
config.stopBubbling = true

# Marks generated members @lombok.Generated so coverage tools do not count them as untested lines,
# and so tools that walk the bytecode can tell hand-written code from generated code.
lombok.addLombokGeneratedAnnotation = true

# @Data is banned everywhere, not only on entities. It bundles @ToString and @EqualsAndHashCode over
# every field, which is the single most common way a hash of a credential ends up in a log line. Ask
# for @Getter and @Setter explicitly; they are the part that is actually boilerplate.
lombok.data.flagUsage = error
lombok.value.flagUsage = error

# @Setter is banned on purpose too. Entities here expose intent-named behaviour — withdraw(), restore(),
# changePassword() — and a generated setter beside them offers a second way to reach the same field that
# skips whatever the named method also does. StaffCredential.changePassword() clearing mustChangePassword
# is exactly that: a setPasswordHash() would look equivalent and would leave the account demanding a
# rotation it had just completed.
lombok.setter.flagUsage = error

# Lets @RequiredArgsConstructor carry Spring's @Value through to the generated constructor parameter.
# Without it, a service with one configured property has to hand-write its whole constructor — so the
# boilerplate returns for an unrelated reason, and only on the classes that inject configuration.
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Value
