# Root of the Lombok configuration tree. Nothing above this directory is consulted.
config.stopBubbling = true

# Marks generated members @lombok.Generated so coverage tools do not count them as untested lines,
# and so tools that walk the bytecode can tell hand-written code from generated code.
lombok.addLombokGeneratedAnnotation = true

# @Data is banned everywhere, not only on entities. It bundles @ToString and @EqualsAndHashCode over
# every field, which is the single most common way a hash of a credential ends up in a log line. Ask
# for @Getter and @Setter explicitly; they are the part that is actually boilerplate.
lombok.data.flagUsage = error
lombok.value.flagUsage = error
