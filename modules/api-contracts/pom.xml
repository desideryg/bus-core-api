<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!--
        SCAFFOLD. Package root tz.co.otapp.buscore.apicontracts. This module builds as a reactor jar so it can be
        implemented, but it owns no entities, controllers, or migrations yet and is NOT a dependency of
        services/bus-core — a module joins the deployable when its first vertical slice lands, not before.
        Implement under internal/: the package root is the published surface, everything else is hidden.

        The internal dependency list below is the module's declared edge set. It is not decoration:
        ModuleDependencyTest asserts this pom and the DAG agree in both directions, and reads bytecode to
        prove no class here touches a module the pom does not name. Adding an edge is an architectural
        decision — change the pom and the DAG in the same commit.
    -->
    <parent>
        <groupId>tz.co.otapp.buscore</groupId>
        <artifactId>bus-core-api</artifactId>
        <version>0.1.0-SNAPSHOT</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <artifactId>api-contracts</artifactId>
    <packaging>jar</packaging>
    <name>api-contracts</name>
    <description>Shared DTOs, the error catalog, and the RFC 9457 problem envelope. Code-first.</description>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

</project>
