    <modelVersion>4.0.0</modelVersion>

    <!--
        SCAFFOLD. Package root tz.co.otapp.buscore.paymentsettlement. This module builds as a reactor jar so it can be
        implemented, but it owns no entities, controllers, or migrations yet and is NOT a dependency of
        services/bus-core — a module joins the deployable when its first vertical slice lands, not before.
        Implement under internal/: the package root is the published surface, everything else is hidden.

        The internal dependency list below is the module's declared edge set. It is not decoration:
        ModuleDependencyTest asserts this pom and the DAG agree in both directions, and reads bytecode to
        prove no class here touches a module the pom does not name. Adding an edge is an architectural
        decision — change the pom and the DAG in the same commit.
    -->
    <parent>
        <groupId>tz.co.otapp.buscore</groupId>
        <artifactId>bus-core-api</artifactId>
        <version>0.1.0-SNAPSHOT</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <artifactId>payment-settlement</artifactId>
    <packaging>jar</packaging>
    <name>payment-settlement</name>
    <description>Internal payment/settlement state and the payment-gateway port the gateway adapter implements.</description>

